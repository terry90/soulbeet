BEETS_PLUGINS="chroma musicbrainz fetchart embedart lyrics lastgenre scrub replaygain mbsync the duplicates missing importadded info smartplaylist inline types ftintitle"
APT_EXTRAS="libchromaprint-tools"
FFMPEG=true
